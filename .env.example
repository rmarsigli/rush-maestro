# Google Ads API
GOOGLE_ADS_CLIENT_ID=your_client_id_here
GOOGLE_ADS_CLIENT_SECRET=your_client_secret_here
GOOGLE_ADS_REDIRECT_URI=http://localhost:3000/auth/google/callback
GOOGLE_ADS_DEVELOPER_TOKEN=your_developer_token_here
GOOGLE_ADS_REFRESH_TOKEN=your_refresh_token_here
GOOGLE_ADS_LOGIN_CUSTOMER_ID=your_mcc_id_here_optional

# Meta (Facebook/Instagram) Graph API
META_PAGE_ACCESS_TOKEN=your_page_access_token_here
META_PAGE_ID=your_page_id_here
META_INSTAGRAM_ACCOUNT_ID=your_instagram_business_account_id_here
# Public URL for media files (required for Instagram publish — use ngrok or similar tunnel)
MEDIA_PUBLIC_BASE_URL=https://your-tunnel.ngrok.io/api/media