# Dependencies
node_modules/

# Environment variables — never commit real credentials
.env
.env.*
!.env.example

# Build outputs
.svelte-kit/
frontend/.svelte-kit/
frontend/dist/
frontend/build/

# Client data — contains sensitive business information and media files (local-only)
/clients/

# Storage — local image files
/storage/images/

# Database — contains operational data, never commit
/db/*.db
/db/*.db-shm
/db/*.db-wal

# Claude Code runtime files
.claude/scheduled_tasks.lock
.claude/settings.local.json

# Dev logs
dev_log.txt

# npm lockfile (project uses bun.lock)
package-lock.json

# Debug and test artifacts
err*.html
test-*.ts

# Editor
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Backend
backend/.env
backend/*.db
backend/tmp/
backend/bin/
frontend/.svelte-kit/
