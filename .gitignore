# Dependencies
node_modules/
ui/node_modules/

# Environment variables — never commit real credentials
.env
.env.*
!.env.example

# Build outputs
ui/.svelte-kit/
ui/dist/
ui/build/

# Client data — contains sensitive business information and media files (local-only)
/clients/

# Database — contains operational data, never commit
/db/*.db
/db/*.db-shm
/db/*.db-wal

# Claude Code runtime files
.claude/scheduled_tasks.lock

# Dev logs
ui/dev_log.txt

# npm lockfile (project uses bun.lock)
ui/package-lock.json

# Debug and test artifacts
ui/err*.html
ui/test-*.ts

# Editor
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
